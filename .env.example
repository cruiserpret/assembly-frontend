# Assembly Frontend Environment
# Vite exposes vars prefixed with VITE_ to the browser

# Backend API URL (leave empty to use Vite proxy — recommended for local dev)
VITE_API_URL=

# For production deployment (e.g. Render), set this to your deployed backend URL:
# VITE_API_URL=https://assembly-backend.onrender.com

# Tier 2 v3-lite YC demo backend (separate from v1)
VITE_API_V3_URL=https://tier-2-assembly-production.up.railway.app
